<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DescriptionActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/infoConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/detailsTextView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="8dp">

        <TextView
            android:id="@+id/enemyNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:text="@string/hardcoded_string_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/enemyImageView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/enemyImageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/image_content_description_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/enemyNameTextView"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/detailsTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="@string/hardcoded_string_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/infoConstraintLayout" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/allLootConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detailsTextView">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lootTypeOneConstraintLayout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/lootTypeTwoConstraintLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/lootTypeOneNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeOneNormalImageView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/lootTypeOneHighImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeOneHighPercentageTextView"
                app:layout_constraintEnd_toStartOf="@id/lootTypeOneNormalImageView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneNameTextView" />

            <TextView
                android:id="@+id/lootTypeOneHighPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/lootTypeOneNormalPercentageTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneHighImageView" />

            <ImageView
                android:id="@+id/lootTypeOneNormalImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeOneNormalPercentageTextView"
                app:layout_constraintEnd_toStartOf="@id/lootTypeOneLowImageView"
                app:layout_constraintStart_toEndOf="@id/lootTypeOneHighImageView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneNameTextView" />

            <TextView
                android:id="@+id/lootTypeOneNormalPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/lootTypeOneLowPercentageTextView"
                app:layout_constraintStart_toEndOf="@id/lootTypeOneHighPercentageTextView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneNormalImageView" />

            <ImageView
                android:id="@+id/lootTypeOneLowImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeOneLowPercentageTextView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/lootTypeOneNormalImageView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneNameTextView" />

            <TextView
                android:id="@+id/lootTypeOneLowPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/lootTypeOneNormalPercentageTextView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeOneLowImageView" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lootTypeTwoConstraintLayout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/lootTypeOneConstraintLayout"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/lootTypeTwoNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeTwoNormalImageView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/lootTypeTwoHighImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeTwoHighPercentageTextView"
                app:layout_constraintEnd_toStartOf="@id/lootTypeTwoNormalImageView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoNameTextView" />

            <TextView
                android:id="@+id/lootTypeTwoHighPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/lootTypeTwoNormalPercentageTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoHighImageView" />

            <ImageView
                android:id="@+id/lootTypeTwoNormalImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeTwoNormalPercentageTextView"
                app:layout_constraintEnd_toStartOf="@id/lootTypeTwoLowImageView"
                app:layout_constraintStart_toEndOf="@id/lootTypeTwoHighImageView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoNameTextView" />

            <TextView
                android:id="@+id/lootTypeTwoNormalPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/lootTypeTwoLowPercentageTextView"
                app:layout_constraintStart_toEndOf="@id/lootTypeTwoHighPercentageTextView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoNormalImageView" />

            <ImageView
                android:id="@+id/lootTypeTwoLowImageView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/image_content_description_placeholder"
                app:layout_constraintBottom_toTopOf="@id/lootTypeTwoLowPercentageTextView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/lootTypeTwoNormalImageView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoNameTextView" />

            <TextView
                android:id="@+id/lootTypeTwoLowPercentageTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hardcoded_string_placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/lootTypeTwoNormalPercentageTextView"
                app:layout_constraintTop_toBottomOf="@id/lootTypeTwoLowImageView" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>